  "keyFeatures": [
    "Stable named .localhost URLs instead of port numbers",
    "Auto-starting reverse proxy on port 1355",
    "HTTP/2 and HTTPS support with auto-generated certificates",
    "Git worktree auto-detection with branch-based subdomains",
    "Wildcard subdomain routing",
    "Static route aliases for external services",
    "Automatic framework port injection (Vite, Astro, Angular, etc.)",
    "Loop detection for misconfigured proxies",
    "Cross-platform (macOS and Linux)"
  ],
  "publicApiSurface": [
    "portless run <cmd>",
    "portless <name> <cmd>",
    "portless alias <name> <port>",
    "portless list",
    "portless trust",
    "portless hosts sync",
    "portless hosts clean",
    "portless proxy start",
    "portless proxy stop",
    "createProxyServer()",
    "RouteStore",
    "RouteInfo",
    "ProxyServerOptions"
  ]
